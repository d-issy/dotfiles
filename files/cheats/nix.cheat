% nix switch

# switch home-manager configuration for this machine
nix run .#switch

% nix flake

# update all flake inputs
nix flake update

# check flake without building derivations
nix flake check --no-build

# show flake outputs
nix flake show

% nix generations

# list home-manager generations
nix run .#generations

% nix gc

# expire old generations and garbage collect
nix run .#gc
